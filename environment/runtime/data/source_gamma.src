DECL counter = 3
DECL y = 7
FUNC compute(p, q) { RETURN p + q }
CALL sum_val = compute(counter, y)
DECL unused_g1 = 111
DECL unused_g2 = 222
DECL accumulator = 0
ASSIGN accumulator = sum_val + counter
IF accumulator { ASSIGN counter = accumulator }
NESTED {
DECL local_n = 50
ASSIGN local_n = local_n + y
NESTED {
DECL deep_gamma = 9
NESTED {
DECL gamma_bottom = 1
NESTED {
DECL gamma_abyss = 0
}
}
}
}
DECL final_gamma = 0
ASSIGN final_gamma = counter + accumulator
