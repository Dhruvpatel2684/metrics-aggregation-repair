DECL x = 50
DECL y = 25
DECL offset = x + y
FUNC multiply(a, b) { RETURN a * b }
CALL product = multiply(x, y)
DECL temp = 0
ASSIGN temp = offset + product
DECL unused_beta = 77
IF temp { ASSIGN x = temp }
NESTED {
DECL inner_val = 200
FUNC scale(n) { RETURN n * 2 }
CALL scaled = scale(inner_val)
NESTED {
DECL nested_x = 5
ASSIGN nested_x = nested_x + 1
NESTED {
DECL deep_beta = 33
NESTED {
DECL very_deep_beta = 11
}
}
}
}
DECL result_beta = 0
ASSIGN result_beta = temp + x
